generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(uuid())
  name             String
  email            String            @unique
  password         String
  phone            String?
  role             Role
  companyId        String?
  createdBy        String?
  isVerified       Boolean           @default(false)
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  verifiedPermits  Permit[]          @relation("PermitVerifier")
  reports          Report[]
  rejections       ReportRejection[]
  company          Company?          @relation(fields: [companyId], references: [id])
  creator          User?             @relation("UserCreator", fields: [createdBy], references: [id])
  createdUsers     User[]            @relation("UserCreator")
  createdCompanies Company[]         @relation("CompanyCreator")
  createdWells     Well[]            @relation("WellCreator")
  approvedReports  Report[]          @relation("ReportApprover")
  auditLogs        AuditLog[]
  sentKadisReports KadisReport[]     @relation("KadisReportSender")

  @@index([companyId])
}

model Company {
  id String @id @default(uuid())

  name    String
  address String?
  email   String?
  phone   String?
  type    String?

  isVerified Boolean @default(false)
  isActive   Boolean @default(true)

  // Kuota pengambilan air tahunan (m³)
  quota     Float @default(0)
  quotaUsed Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy String?

  creator User? @relation("CompanyCreator", fields: [createdBy], references: [id])

  businesses Business[]
  users      User[]
  wells      Well[]

  @@index([createdBy])
}

model Business {
  id        String  @id @default(uuid())
  name      String
  address   String?
  phone     String?
  companyId String

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  company   Company  @relation(fields: [companyId], references: [id])
  wells     Well[]

  @@index([companyId])
}

model Well {
  id         String  @id @default(uuid())
  name       String
  companyId  String
  businessId String?

  latitude            Float?
  longitude           Float?
  locationDescription String?
  wellType            WellType

  depthMeter     Float?
  diameterInch   Float?
  casingDiameter Float?
  pumpCapacity   Float?
  pumpDepth      Float?
  pipeDiameter   Float?

  // Pengukuran Muka Air Tanah
  staticWaterLevel          Float? // Kedalaman muka air tanah (m dari permukaan)
  waterLevelTrend           WaterLevelTrend?
  lastWaterLevelMeasurement DateTime?

  // Status untuk workflow supervisor approval
  status WellStatus @default(approved) // approved untuk existing data, pending_approval untuk dari supervisor

  supervisorNote String?  // Catatan ketidaksesuaian dari supervisor

  createdBy  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
  isActive   Boolean  @default(true)
  isVerified Boolean  @default(false)

  company  Company   @relation(fields: [companyId], references: [id])
  business Business? @relation(fields: [businessId], references: [id])
  creator  User?     @relation("WellCreator", fields: [createdBy], references: [id])

  permits Permit[]
  reports Report[]

  @@index([companyId])
  @@index([businessId])
  @@index([createdBy])
}

model Report {
  id String @id @default(uuid())

  wellId String
  userId String

  waterDepth   Float
  waterUsage   Float?
  waterQuality WaterQuality?

  hasPermit   Boolean  @default(false)
  description String?
  photos      String[]

  status ReportStatus @default(PENDING)

  approvedBy String?
  approvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User  @relation(fields: [userId], references: [id])
  approver User? @relation("ReportApprover", fields: [approvedBy], references: [id])
  well     Well  @relation(fields: [wellId], references: [id])

  rejection ReportRejection?

  @@index([wellId])
  @@index([userId])
  @@index([status])
  @@index([approvedBy])
}

model Permit {
  id           String       @id @default(uuid())
  wellId       String
  permitNumber String?
  issueDate    DateTime?
  expiryDate   DateTime?
  documentUrl  String?
  status       PermitStatus @default(pending)
  verifiedBy   String?
  verifiedAt   DateTime?
  createdAt    DateTime     @default(now())
  verifier     User?        @relation("PermitVerifier", fields: [verifiedBy], references: [id])
  well         Well         @relation(fields: [wellId], references: [id])

  @@index([wellId])
  @@index([status])
}

model ReportRejection {
  id         String   @id @default(uuid())
  reportId   String   @unique
  reason     String
  rejectedBy String?
  rejectedAt DateTime @default(now())
  user       User?    @relation(fields: [rejectedBy], references: [id])
  report     Report   @relation(fields: [reportId], references: [id])
}

enum Role {
  super_admin
  admin_perusahaan
  kepala_instansi
  supervisor
}

enum ReportStatus {
  PENDING
  APPROVED
  REJECTED
}

enum WaterQuality {
  BAIK
  SEDANG
  BURUK
}

enum PermitStatus {
  pending
  approved
  rejected
}

enum WellType {
  sumur_pantau
  sumur_gali
  sumur_bor
}

enum WaterLevelTrend {
  rising
  falling
  stable
  unknown
}

enum WellStatus {
  draft
  pending_approval
  reviewed
  approved
  rejected
}

model KadisReport {
  id            String   @id @default(uuid())
  title         String
  companyId     String?
  companyName   String
  totalWells    Int
  avgWaterLevel Float?
  notes         String?
  pdfContent    String?
  sentBy        String
  sentAt        DateTime @default(now())

  sender User @relation("KadisReportSender", fields: [sentBy], references: [id])

  @@index([sentAt])
  @@index([sentBy])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  userName  String
  action    String // create, update, delete, approve, reject
  target    String // well, business, etc
  targetId  String? // id dari well/business yang diubah
  details   String? // JSON string untuk perubahan detail
  oldData   String? // JSON string data lama (untuk update/reject)
  newData   String? // JSON string data baru (untuk update)
  ip        String?
  severity  String   @default("info")
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([targetId])
  @@index([createdAt])
  @@index([severity])
}
