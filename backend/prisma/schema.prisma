// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// enum section

// enum role
enum Role {
  super_admin
  admin_perusahaan
  kepala_instansi
  supervisor
}

// enum report status
enum ReportStatus {
  diproses
  diterima
  ditolak
}

// enum permit status
enum PermitStatus {
  pending
  approved
  rejected
}

// enum well type
enum WellType {
  perusahaan
  non_perusahaan
  rumah_tangga
}

// model user
model User {
  id       String  @id @default(uuid())
  name     String
  email    String  @unique
  password String
  phone    String?

  role Role

  companyId String?
  createdBy String?

  isVerified Boolean @default(false)
  isActive   Boolean @default(true)

  createdAt DateTime @default(now())

  // relasi

}

// model company
model Company {
  id String @id @default(uuid())
  name String
  address String?
  email String?
  phone String?

  type String?
  isVerified Boolean @default(false)

  createdAt DateTime @default(now())

  // relasi
  
}

// model business 
model Business {
  id String @id @default(uuid())
  name String
  address String?
  phone String?

  companyId String
  
  createdAt DateTime @default(now())

  // relasi
}

// model well (sumur)
model Well {
  id String @id @default(uuid())
  name String

  companyId String

  latitude Float?
  longitude Float?
  locationDescription String?

  wellType WellType

  depthMeter Float?
  diameterInch Float?
  casingDiameter Float?
  pumpCapacity Float?
  pumpDepth Float?
  pipeDiameter Float?

  createdAt DateTime @default(now())

  // relasi
}

// model report (pelaporan)
model Report {
  id String @id @default(uuid())
  
  wellId String
  userId String

  waterDepth Float?
  waterUsage Float?
  waterQuality String?

  hasPermint Boolean @default(false)

  description String?
  photoUrl String?

  status ReportStatus @default(diproses)
  verifiedBy String?
  verifiedAt DateTime?

  createdAt DateTime @default(now())

  // relasi
}

// model permit (perizinan)
model Permit {
  id String @id @default(uuid())
  
  wellId String

  permitNumber String
  issueDate DateTime
  expiryDate DateTime

  documentUrl String?

  status PermitStatus @default(pending)
  
  verfiedBy String?
  verifiedAt DateTime?

  createdAt DateTime @default(now())

  // relasi
}