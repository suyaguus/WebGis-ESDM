generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String            @id @default(uuid())
  name            String
  email           String            @unique
  password        String
  phone           String?
  role            Role
  companyId       String?
  createdBy       String?
  isVerified      Boolean           @default(false)
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  verifiedPermits Permit[]          @relation("PermitVerifier")
  reports         Report[]
  verifiedReports Report[]          @relation("ReportVerifier")
  rejections      ReportRejection[]
  company         Company?          @relation(fields: [companyId], references: [id])
  creator         User?             @relation("UserCreator", fields: [createdBy], references: [id])
  createdUsers    User[]            @relation("UserCreator")

  @@index([companyId])
}

model Company {
  id         String     @id @default(uuid())
  name       String
  address    String?
  email      String?
  phone      String?
  type       String?
  isVerified Boolean    @default(false)
  createdAt  DateTime   @default(now())
  businesses Business[]
  users      User[]
  wells      Well[]
}

model Business {
  id        String   @id @default(uuid())
  name      String
  address   String?
  phone     String?
  companyId String
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id])
}

model Well {
  id                  String   @id @default(uuid())
  name                String
  companyId           String
  latitude            Float?
  longitude           Float?
  locationDescription String?
  wellType            WellType
  depthMeter          Float?
  diameterInch        Float?
  casingDiameter      Float?
  pumpCapacity        Float?
  pumpDepth           Float?
  pipeDiameter        Float?
  createdAt           DateTime @default(now())
  permits             Permit[]
  reports             Report[]
  company             Company  @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

model Report {
  id           String        @id @default(uuid())

  wellId       String
  userId       String

  waterDepth   Float
  waterUsage   Float?

  waterQuality WaterQuality?

  hasPermit    Boolean       @default(false)

  description  String?

  photos       String[]      

  status       ReportStatus  @default(PENDING)

  approvedBy   String?
  approvedAt   DateTime?

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  approver     User?         @relation("ReportVerifier", fields: [approvedBy], references: [id])
  well         Well          @relation(fields: [wellId], references: [id])

  rejection    ReportRejection?

  @@index([wellId])
  @@index([userId])
  @@index([status])
}

model Permit {
  id           String       @id @default(uuid())
  wellId       String
  permitNumber String?
  issueDate    DateTime?
  expiryDate   DateTime?
  documentUrl  String?
  status       PermitStatus @default(pending)
  verifiedBy   String?
  verifiedAt   DateTime?
  createdAt    DateTime     @default(now())
  verifier     User?        @relation("PermitVerifier", fields: [verifiedBy], references: [id])
  well         Well         @relation(fields: [wellId], references: [id])

  @@index([wellId])
  @@index([status])
}

model ReportRejection {
  id         String   @id @default(uuid())
  reportId   String   @unique
  reason     String
  rejectedBy String?
  rejectedAt DateTime @default(now())
  user       User?    @relation(fields: [rejectedBy], references: [id])
  report     Report   @relation(fields: [reportId], references: [id])
}

enum Role {
  super_admin
  admin_perusahaan
  kepala_instansi
  supervisor
}

enum ReportStatus {
  PENDING
  APPROVED
  REJECTED
}

enum WaterQuality {
  GOOD
  MEDIUM
  BAD
}

enum PermitStatus {
  pending
  approved
  rejected
}

enum WellType {
  perusahaan
  non_perusahaan
  rumah_tangga
}
