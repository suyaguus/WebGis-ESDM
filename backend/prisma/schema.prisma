// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// enum section

// enum role
enum Role {
  super_admin
  admin_perusahaan
  kepala_instansi
  supervisor
}

// enum report status
enum ReportStatus {
  diproses
  diterima
  ditolak
}

// enum permit status
enum PermitStatus {
  pending
  approved
  rejected
}

// enum well type
enum WellType {
  perusahaan
  non_perusahaan
  rumah_tangga
}

// model user
model User {
  id       String  @id @default(uuid())
  name     String
  email    String  @unique
  password String
  phone    String?

  role Role

  companyId String?
  createdBy String?

  isVerified Boolean @default(false)
  isActive   Boolean @default(true)

  createdAt DateTime @default(now())

  // relasi

}

// model company
model Company {
  id String @id @default(uuid())
  name String
  address String?
  email String?
  phone String?

  type String?
  isVerified Boolean @default(false)

  createdAt DateTime @default(now())

  // relasi
  
}

// model business 
model Business {
  id String @id @default(uuid())
  name String
  address String?
  phone String?

  companyId String
  
  createdAt DateTime @default(now())

  // relasi
}